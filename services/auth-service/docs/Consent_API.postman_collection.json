					"body": "{\n  \"statusCode\": \"001\",\n  \"response\": \"ERROR\",\n  \"data\": {\n    \"statusCode\": 404,\n    \"message\": \"User not found\"\n  },\n  \"traceId\": \"abc123-def456-ghi789\"\n}"
				}
