		{
			"name": "Store User Consent",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Postman-Token",
						"value": "test-token",
						"description": "Add this header to skip encryption for testing"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"userId\": \"user@example.com\",\n  \"consentIds\": [1, 2, 3, 4, 5],\n  \"agreed\": 1\n}",
