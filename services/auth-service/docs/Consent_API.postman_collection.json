						"api",
						"v1",
						"auth",
						"consents",
						"store"
					]
				},
				"description": "Stores user consent acceptance. Only stores NEW consent IDs (skips already accepted ones).\n\n**Note:** Frontend can send all consent IDs (already accepted + new ones). System will automatically filter and only store new ones."
			},
