<configuration>
    <springProperty name="service" source="spring.application.name"/>
    <springProperty name="LOG_DIR" source="logging.server.directory"/>
    <springProperty name="serverName" source="server.name"/>

    <!-- Daily rolling logs with 90-day retention -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Directly write and roll by date -->
            <fileNamePattern>${LOG_DIR}/${service}_${serverName}_%d{yyyy-MM-dd}.log</fileNamePattern>

            <!-- Keep 90 days of logs -->
            <maxHistory>90</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS,Asia/Kolkata} %logger{36} - %line - %method - %msg [%thread] %-5level%n</pattern>
        </encoder>
    </appender>

    <!-- Console appender with masking -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="com.medgo.patternlayout.MaskingPatternLayout">
                <maskPattern>"panNo"\s*:\s*"(.*?)"</maskPattern>
                <maskPattern>"mobileNo"\s*:\s*"(.*?)"</maskPattern>
                <maskPattern>panNo='(.*?)'</maskPattern>
                <maskPattern>mobileNo='(.*?)'</maskPattern>
                <maskPattern>pan number\s*:\s*(\w+)</maskPattern>
                <maskPattern>mobile number\s*:\s*(\d{10})</maskPattern>
                <maskPattern>\b([A-Z]{5}[0-9]{4}[A-Z])\b</maskPattern>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS,Asia/Kolkata} [deviceId=%X{deviceId}] %logger{36} - %line - %method - %msg [%thread] %-5level%n</pattern>
            </layout>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="FILE"/>
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
